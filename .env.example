# Tracking — loaded only after visitor cookie consent

# Google Analytics 4 (use if not routing through GTM)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager (preferred if all tags live in GTM)
NEXT_PUBLIC_GTM_CONTAINER_ID=GTM-XXXXXXX

# Microsoft Bing UET
NEXT_PUBLIC_BING_UET_TAG_ID=12345678

# Meta (Facebook / Instagram) Pixel
NEXT_PUBLIC_META_PIXEL_ID=1234567890123456

# LinkedIn Insight Tag partner ID
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=1234567

# LeadSpider CRM — full URL to the tracking/embed script
NEXT_PUBLIC_LEADSPIDER_SCRIPT_URL=https://your-leadspider-instance.example.com/tracking.js
